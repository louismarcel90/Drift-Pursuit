{
  "name": "@drift-pursuit-grid/terminal-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/main.ts",
    "dev:realtime": "tsx src/realtime-main.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint --config ../../eslint.config.mjs .",
    "test": "vitest run --config ./vitest.config.ts",
    "test:watch": "vitest --watch",
    "clean": "rimraf dist coverage"
  },
  "dependencies": {
    "@drift-pursuit-grid/contracts": "workspace:*",
    "@drift-pursuit-grid/domain": "workspace:*",
    "@drift-pursuit-grid/simulation-core": "workspace:*",
    "@drift-pursuit-grid/renderer-ascii": "workspace:*",
    "@drift-pursuit-grid/input-system": "workspace:*",
    "@drift-pursuit-grid/replay-engine": "workspace:*"

  },
  
  "devDependencies": {
    "@drift-pursuit-grid/shared-config": "workspace:*",
    "@drift-pursuit-grid/simulation-core": "workspace:*"
  }
}