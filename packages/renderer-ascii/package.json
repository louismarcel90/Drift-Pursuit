{
  "name": "@drift-pursuit-grid/renderer-ascii",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint --config ../../eslint.config.mjs .",
    "test": "vitest run --config vitest.config.ts --passWithNoTests",
    "test:watch": "vitest --watch",
    "clean": "rimraf dist coverage"
  },
  "dependencies": {
    "@drift-pursuit-grid/contracts": "workspace:*",
    "@drift-pursuit-grid/domain": "workspace:*",
    "@drift-pursuit-grid/state-store": "workspace:*"
  },
  "devDependencies": {
    "@drift-pursuit-grid/shared-config": "workspace:*"
  }
}
